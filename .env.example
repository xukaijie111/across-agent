# 复制为 .env 后填写（.env 勿提交 git）
# cp .env.example .env

# 必填：百炼 DashScope 或 OpenAI 兼容 API Key
OPENAI_API_KEY=sk-your-api-key-here

# 百炼兼容模式（默认）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v3

# MySQL：session / 聊天历史 / LangGraph checkpoint
# 不配 MYSQL_HOST 时退回内存 session + 本地 sqlite（仅适合本地调试）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=agent_playground
