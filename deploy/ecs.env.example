# 复制为 deploy/ecs.env 后填写（deploy/ecs.env 已在 .gitignore，勿提交）
#
# ECS 连接
ECS_HOST=106.15.5.36
ECS_USER=root
ECS_PORT=22

# 密码登录（留空则使用本机 SSH 密钥）
# ECS_PASSWORD=

# 远程目录
ECS_REMOTE_DIR=/opt/agent-playground

# 可选：绑定域名（写入 Nginx server_name，如 agentnow.fun www.agentnow.fun）
# DEPLOY_DOMAIN=www.agentnow.fun
