[Unit]
Description=Agent Playground API (FastAPI + uvicorn)
After=network.target mysqld.service
Wants=mysqld.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/agent-playground/server
EnvironmentFile=/opt/agent-playground/.env
ExecStart=/opt/agent-playground/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
